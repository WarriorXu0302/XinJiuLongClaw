# 拷贝为 .env.development / .env.testing / .env.production 并填真值后本地使用
# 这些文件不进 git（见 .gitignore）
# 所有变量必须以 VITE_APP_ 开头，代码里用 import.meta.env.VITE_APP_XXX

# 环境配置标识（development / testing / production）
VITE_APP_ENV = 'development'

# 微信 公众号 appid（不是小程序 appid）
# 小程序 appid 在 manifest.json 的 mp-weixin.appid 字段
# 生产值在微信开放平台拿，测试环境用官方 demo appid 或留空走 mock
VITE_APP_MP_APPID = ''

# 统一接口域名（开发指向本地后端，生产指向实际部署域名）
VITE_APP_BASE_API = 'http://127.0.0.1:8002'

# 图片 / 静态资源 CDN 域名
VITE_APP_RESOURCES_URL = ''
